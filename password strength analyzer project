#!/usr/bin/env python3
"""
Password Strength Analyzer & Generator
Compatible with Python 3.6+ | Kali Linux
"""

import re
import math
import getpass
import secrets
import string
import argparse
import sys

# ─── Optional color support (pip install colorama) ───────────────────────────
try:
    from colorama import init, Fore, Style
    init(autoreset=True)
    RED     = Fore.RED
    YELLOW  = Fore.YELLOW
    GREEN   = Fore.GREEN
    CYAN    = Fore.CYAN
    BOLD    = Style.BRIGHT
    RESET   = Style.RESET_ALL
except ImportError:
    RED = YELLOW = GREEN = CYAN = BOLD = RESET = ""


# ─── Strength Thresholds ──────────────────────────────────────────────────────
STRENGTH_LEVELS = [
    (2,  RED    + "Very Weak"),
    (4,  RED    + "Weak"),
    (6,  YELLOW + "Moderate"),
    (7,  GREEN  + "Strong"),
    (99, GREEN  + BOLD + "Very Strong"),
]

# ─── Common patterns to penalise ─────────────────────────────────────────────
COMMON_PATTERNS = [
    r'123456', r'password', r'qwerty', r'admin', r'letmein',
    r'welcome', r'monkey', r'abc123', r'iloveyou', r'sunshine',
    r'princess', r'dragon', r'master', r'login', r'passw0rd',
]

KEYBOARD_WALKS = [
    r'qwerty', r'asdf', r'zxcv', r'qwert', r'asdfg', r'zxcvb',
    r'1234', r'2345', r'3456', r'4567', r'5678', r'6789', r'7890',
]

SEQUENTIAL_ALPHA = (
    r'(?:abc|bcd|cde|def|efg|fgh|ghi|hij|ijk|jkl|klm|lmn|'
    r'mno|nop|opq|pqr|qrs|rst|stu|tuv|uvw|vwx|wxy|xyz)'
)


# ─── Entropy Calculator ───────────────────────────────────────────────────────
def calculate_entropy(password: str) -> float:
    """Shannon entropy in bits — higher = more random."""
    if not password:
        return 0.0
    freq = {}
    for ch in password:
        freq[ch] = freq.get(ch, 0) + 1
    length = len(password)
    return -sum((c / length) * math.log2(c / length) for c in freq.values())


# ─── Core Analyser ────────────────────────────────────────────────────────────
def check_password_strength(password: str):
    """
    Analyse a password and return (score, strength_label, feedback_list).
    Score range: 0–10 (before clamping to label buckets).
    """
    score = 0
    feedback = []

    # 1. Length
    length = len(password)
    if length < 8:
        feedback.append("❌  Too short — use at least 8 characters")
    elif length < 12:
        score += 1
        feedback.append("⚠️   Acceptable length, but 12+ is better")
    elif length < 16:
        score += 2
        feedback.append("✅  Good length (12–15 chars)")
    else:
        score += 3
        feedback.append("✅  Excellent length (16+ chars)")

    # 2. Character variety
    checks = {
        r'[A-Z]':              ("✅  Contains uppercase letters",
                                "❌  Add uppercase letters (A–Z)"),
        r'[a-z]':              ("✅  Contains lowercase letters",
                                "❌  Add lowercase letters (a–z)"),
        r'\d':                 ("✅  Contains digits",
                                "❌  Add numbers (0–9)"),
        r'[!@#$%^&*()\-_=+\[\]{}|;:,.<>?/\\\'"`~]':
                               ("✅  Contains special characters",
                                "❌  Add special characters (!@#$%^&* etc.)"),
    }
    for pattern, (good, bad) in checks.items():
        if re.search(pattern, password):
            score += 1
            feedback.append(good)
        else:
            feedback.append(bad)

    # 3. Entropy bonus
    entropy = calculate_entropy(password)
    if entropy >= 4.0:
        score += 1
        feedback.append(f"✅  High character entropy ({entropy:.2f} bits)")
    elif entropy < 2.5:
        score -= 1
        feedback.append(f"⚠️   Low character entropy ({entropy:.2f} bits) — too predictable")

    # 4. Common password patterns
    for pattern in COMMON_PATTERNS:
        if re.search(pattern, password, re.IGNORECASE):
            score -= 2
            feedback.append(f"❌  Contains common password pattern: '{pattern}'")
            break

    # 5. Keyboard walks
    for walk in KEYBOARD_WALKS:
        if re.search(walk, password, re.IGNORECASE):
            score -= 1
            feedback.append(f"❌  Contains keyboard walk pattern: '{walk}'")
            break

    # 6. Repeated characters (e.g. 'aaa')
    if re.search(r'(.)\1{2,}', password):
        score -= 1
        feedback.append("❌  Contains repeated characters (e.g. 'aaa')")

    # 7. Sequential alpha (e.g. 'abc', 'xyz')
    if re.search(SEQUENTIAL_ALPHA, password, re.IGNORECASE):
        score -= 1
        feedback.append("❌  Contains sequential letters (e.g. 'abc')")

    # 8. All same case / all digits
    if password.isdigit():
        score -= 1
        feedback.append("❌  Password is all digits — very guessable")
    if password.isalpha() and (password.isupper() or password.islower()):
        score -= 1
        feedback.append("❌  Password uses only one letter case with no digits/symbols")

    # Clamp score
    score = max(0, min(score, 10))

    # Map to label
    strength = RESET + "Unknown"
    for threshold, label in STRENGTH_LEVELS:
        if score <= threshold:
            strength = label + RESET
            break

    return score, strength, feedback


# ─── Password Generator ───────────────────────────────────────────────────────
def generate_strong_password(length: int = 16) -> str:
    """Generate a cryptographically strong password."""
    if length < 8:
        raise ValueError("Minimum length is 8 characters.")

    uppercase = string.ascii_uppercase
    lowercase = string.ascii_lowercase
    digits     = string.digits
    special    = '!@#$%^&*()-_=+[]{}|;:,.<>?'

    # Guarantee at least one of each class
    password = [
        secrets.choice(uppercase),
        secrets.choice(lowercase),
        secrets.choice(digits),
        secrets.choice(special),
    ]

    all_chars = uppercase + lowercase + digits + special
    password += [secrets.choice(all_chars) for _ in range(length - 4)]

    secrets.SystemRandom().shuffle(password)
    return ''.join(password)


# ─── Display helpers ──────────────────────────────────────────────────────────
def print_banner():
    banner = f"""
{CYAN}{BOLD}╔══════════════════════════════════════════╗
║      🔐  Password Strength Analyzer      ║
║         Python 3 · Kali Linux            ║
╚══════════════════════════════════════════╝{RESET}
"""
    print(banner)


def print_analysis(password: str):
    score, strength, feedback = check_password_strength(password)
    max_score = 10

    # Score bar
    filled = int((score / max_score) * 20)
    bar = GREEN + "█" * filled + RESET + "░" * (20 - filled)

    print(f"\n{BOLD}═══ Analysis Results ═══{RESET}")
    print(f"  Strength : {strength}")
    print(f"  Score    : {BOLD}{score}/{max_score}{RESET}  [{bar}]")
    print(f"\n{BOLD}Feedback:{RESET}")
    for item in feedback:
        print(f"  {item}")
    print()


# ─── CLI Entry Point ──────────────────────────────────────────────────────────
def parse_args():
    parser = argparse.ArgumentParser(
        description="Password Strength Analyzer & Generator",
        formatter_class=argparse.RawTextHelpFormatter,
    )
    subparsers = parser.add_subparsers(dest="command")

    # analyse sub-command
    analyze_p = subparsers.add_parser("analyze", help="Analyse a password")
    analyze_p.add_argument(
        "-p", "--password",
        help="Password to analyse (omit for secure prompt)",
        default=None,
    )

    # generate sub-command
    gen_p = subparsers.add_parser("generate", help="Generate a strong password")
    gen_p.add_argument(
        "-l", "--length",
        type=int,
        default=16,
        help="Length of the generated password (default: 16)",
    )
    gen_p.add_argument(
        "-n", "--count",
        type=int,
        default=1,
        help="Number of passwords to generate (default: 1)",
    )

    return parser, parser.parse_args()


def interactive_menu():
    print_banner()
    print(f"  {BOLD}1.{RESET} Analyse a password")
    print(f"  {BOLD}2.{RESET} Generate a strong password")
    print(f"  {BOLD}3.{RESET} Exit\n")

    choice = input("Choose an option [1/2/3]: ").strip()

    if choice == "1":
        try:
            password = getpass.getpass("  Enter password (hidden): ")
        except Exception:
            password = input("  Enter password: ")
        print_analysis(password)

    elif choice == "2":
        try:
            length = int(input("  Password length [default 16]: ").strip() or "16")
        except ValueError:
            length = 16
        try:
            count = int(input("  How many passwords? [default 1]: ").strip() or "1")
        except ValueError:
            count = 1

        if length < 8:
            print(f"{RED}Minimum length is 8.{RESET}")
            return

        print(f"\n{BOLD}Generated Password(s):{RESET}")
        for i in range(count):
            pwd = generate_strong_password(length)
            print(f"  {CYAN}{pwd}{RESET}")
        print(f"\n{YELLOW}⚠  Store these in a password manager (e.g. KeePassXC, Bitwarden).{RESET}\n")

    elif choice == "3":
        print("Goodbye!")
        sys.exit(0)
    else:
        print(f"{RED}Invalid choice.{RESET}")


def main():
    parser, args = parse_args()

    if args.command == "analyze":
        print_banner()
        if args.password:
            print_analysis(args.password)
        else:
            try:
                password = getpass.getpass("  Enter password (hidden): ")
            except Exception:
                password = input("  Enter password: ")
            print_analysis(password)

    elif args.command == "generate":
        print_banner()
        if args.length < 8:
            print(f"{RED}Minimum length is 8.{RESET}")
            sys.exit(1)
        print(f"\n{BOLD}Generated Password(s):{RESET}")
        for _ in range(args.count):
            print(f"  {CYAN}{generate_strong_password(args.length)}{RESET}")
        print(f"\n{YELLOW}⚠  Store these in a password manager.{RESET}\n")

    else:
        # No sub-command → interactive menu
        interactive_menu()


if __name__ == "__main__":
    main()
